    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9",
    "dotenv": "^17.3.1",
    "postcss": "^8",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
